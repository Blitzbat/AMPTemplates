App.DisplayName=Angels Fall First
App.RootDir=./angels-fall-first/
App.BaseDirectory=./angels-fall-first/407480/
App.StoresSupported=
App.StoreDownloadLocations=
App.ExecutableWin=407480\Binaries\Win64\AFFGameServer.exe
App.ExecutableLinux=/usr/bin/wine
App.WorkingDir=407480/Binaries/Win64
App.LinuxCommandLineArgs="./AFFGameServer.exe"
App.WindowsCommandLineArgs=
App.CommandLineArgs={{$PlatformArgs}} {{ServerMap}}?GamePassword={{GamePassword}}?MaxPlayers={{$MaxUsers}}?NumPlay={{NumPlay}}?BalanceBots={{BalanceBots}}?AILevel={{AILevel}}?BriefingTime={{BriefingTime}}?RandomCommander={{RandomCommander}}?RedStartingTickets={{RedStartingTickets}}?BlueStartingTickets={{BlueStartingTickets}}?FriendlyFire={{FriendlyFire}}{{CustomOptions}} -Port={{$GamePort}} -QueryPort={{$QueryPort}} -MultiHome={{$ApplicationIPBinding}} -configsubdir=AMP -log=AMP/server.log -seekfreeloadingserver
App.UseLinuxIOREDIR=False
App.AppSettings={}
App.EnvironmentVariables={"SteamAppId":"367270","WINEPREFIX":"{{$FullRootDir}}.wine","WINEARCH":"win64","WINEDEBUG":"-all"}
App.CommandLineParameterFormat=-{0}={1}
App.CommandLineParameterDelimiter= 
App.ExitMethod=OS_CLOSE
App.ExitTimeout=30
App.ExitString=stop
App.ExitFile=app_exit.lck
App.HasWriteableConsole=False
App.HasReadableConsole=False
App.UDPLogger=False
App.SupportsLiveSettingsChanges=False
App.LiveSettingChangeCommandFormat=set {0} "{1}"
App.ForceIPBinding=False
App.SupportsIPv6=False
App.ApplicationIPBinding=0.0.0.0
App.Ports=@IncludeJson[angels-fall-firstports.json]
App.AdminPortRef=0
App.PrimaryApplicationPortRef=GamePort
App.UniversalSleepApplicationUDPPortRef=GamePort
App.UniversalSleepSteamQueryPortRef=QueryPort
App.MaxUsers=64
App.UseRandomAdminPassword=False
App.PersistRandomPassword=False
App.RemoteAdminPassword=
App.AdminMethod=STDIO
App.IgnoreSTDOUTAfterRCON=False
App.AdminLoginTransform=None
App.LoginTransformPrefix=
App.RCONConnectDelaySeconds=5
App.RCONConnectRetrySeconds=5
App.RCONHeartbeatMinutes=0
App.RCONHeartbeatCommand=ping
App.TelnetLoginFormat={0}
App.UpdateSources=@IncludeJson[angels-fall-firstupdates.json]
App.PreStartStages=[]
App.ForceUpdate=False
App.ForceUpdateReason=
App.Compatibility=None
App.SteamUpdateAnonymousLogin=True
App.SteamForceLoginPrompt=False
App.RapidStartup=False
App.DumpFullChildProcessTree=False
App.MonitorChildProcessName=^.*AFFGameServer\.exe.*-Port={{$GamePort}}.*$
App.SupportsUniversalSleep=False
App.WakeupMode=Any
App.ApplicationReadyMode=Immediate
